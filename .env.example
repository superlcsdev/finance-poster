# ── finance-poster environment config ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub!

# ── AI (same keys as health poster — reuse them) ─────────────────────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── News (optional) ───────────────────────────────────────────────────────────
NEWS_API_KEY=

# ── Facebook (same Page as health poster) ────────────────────────────────────
FB_PAGE_ID=
FB_ACCESS_TOKEN=

# ── Image generation fallback ────────────────────────────────────────────────
HF_API_TOKEN=
